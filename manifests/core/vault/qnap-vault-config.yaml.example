# Example ConfigMap for QNAP Vault configuration
# Copy this to qnap-vault-config.yaml and update with your values
apiVersion: v1
kind: ConfigMap
metadata:
  name: qnap-vault-config
  namespace: vault
data:
  # Replace with your actual QNAP/NAS vault configuration
  config.yaml: |
    transit:
      address: "http://YOUR-NAS-IP:8200"  # Your NAS Vault address
      mountPath: "transit"
      keyName: "autounseal"
      tlsSkipVerify: true