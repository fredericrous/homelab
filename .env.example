# Homelab Environment Configuration
# Copy this to .env and adjust values for your environment

# QNAP/NAS Configuration
QNAP_VAULT_ADDR=http://YOUR-NAS-IP:8200
QNAP_VAULT_TOKEN=  # Your QNAP Vault token (will be generated during setup)

# OVH DNS Configuration (for Let's Encrypt)
OVH_APPLICATION_KEY=your-application-key
OVH_APPLICATION_SECRET=your-application-secret
OVH_CONSUMER_KEY=your-consumer-key

# Cluster Configuration
CLUSTER_DOMAIN=yourdomain.com

# Optional: Override default IPs (adjust to your network)
# CONTROL_PLANE_IP=192.168.1.100
# WORKER1_IP=192.168.1.101
# WORKER2_IP=192.168.1.102

# Storage Configuration
NFS_SERVER=YOUR-NAS-IP
NFS_PATH=/path/to/your/nfs/share

# Email for Let's Encrypt
LETSENCRYPT_EMAIL=your-email@example.com