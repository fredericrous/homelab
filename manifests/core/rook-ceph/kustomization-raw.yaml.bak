apiVersion: kustomize.config.k8s.io/v1beta1
kind: Kustomization

namespace: rook-ceph

resources:
- https://raw.githubusercontent.com/rook/rook/v1.15.8/deploy/examples/crds.yaml
- https://raw.githubusercontent.com/rook/rook/v1.15.8/deploy/examples/common.yaml
- https://raw.githubusercontent.com/rook/rook/v1.15.8/deploy/examples/operator.yaml
- cluster-minimal.yaml
- fix-pool-size.yaml

patches:
- path: operator-patch.yaml
  target:
    kind: Deployment
    name: rook-ceph-operator
- path: namespace-patch.yaml
  target:
    kind: Namespace
    name: rook-ceph
